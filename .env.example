# -------------------------------------------------------------
# REQUIRED: Google Drive Service Account Configuration
# -------------------------------------------------------------
# The path to your Service Account JSON key file.
# You can generate this in Google Cloud Console -> IAM & Admin -> Service Accounts -> Keys
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# The ID of the Google Drive folder to monitor
# E.g., if URL is https://drive.google.com/drive/folders/1UsOz5AX2m77aru-xiYk9iFercTJQFqUa, the ID is 1UsOz5AX2m77aru-xiYk9iFercTJQFqUa
FOLDER_ID=your_folder_id_here

# -------------------------------------------------------------
# OPTIONAL: Server Configuration
# -------------------------------------------------------------
# Port for the Express server to run on (Default: 3001)
PORT=3001

# Limit API access to specific origins (e.g., http://localhost:5173, https://your-domain.com).
# Leave empty or set to * to allow all origins.
ALLOWED_ORIGIN=*
